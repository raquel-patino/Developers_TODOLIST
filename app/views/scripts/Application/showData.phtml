<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My To-Do</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-8">
    <div class="max-w-3xl mx-auto bg-teal-100 p-6 rounded-lg shadow-lg">
        <h1 class="text-center text-3xl bg-gray-100 rounded-lg w-1/2 font-serif font-bold text-gray-800 
        mb-4 mx-auto">MY TO-DO</h1>
        <?php if (isset($_SESSION["success"])): ?>
        <div class="bg-green-200 text-green-800 p-4 rounded-lg mb-4">
            <?= $_SESSION["success"]; ?>
        </div>
     <?php unset($_SESSION["success"]);?>
     <?php elseif (isset($_SESSION["error"])): ?>
        <div class="bg-red-200 text-red-800 p-4 rounded-lg mb-4">
            <?= $_SESSION["error"]; ?>
        </div>
 <?php unset($_SESSION["error"]);?> 
        <?php endif; ?>
<?php if (isset($_SESSION['popup_data'])): ?>
    <?php include 'updateTask.phtml'; ?>
<?php endif; ?>
<?php if (isset($_SESSION['delete_popup'])): ?>
    <?php include 'deleteConfirmation.phtml'; ?>
<?php endif; ?>

        <!-- Botón para agregar tarea -->
        <div class="flex justify-between items-center mb-4">
        <a href="<?= WEB_ROOT?>/createTask">
            <button class="bg-green-500 text-white px-4 py-2 rounded-lg flex items-center">
                <span class="text-lg">➕</span>
                <span class="ml-2">New Task</span>
                </button>
        </a>
            <form action="<?= WEB_ROOT?>/search" method="get">
                <input type="text" name= "search" placeholder="Search title..."class="border px-4 py-2 rounded-lg w-3/3">
            </form>
        </div>

        <!-- Lista de tareas -->
        <ul class="space-y-4">
            <?php if(count($this->tasks)>0): ?>
                <?php foreach ($this->tasks as $task): ?>
                    <li class="bg-white p-4 rounded-lg shadow flex flex-col">
                        <div class="flex justify-between items-center">
                            <span class="px-4 py-2 rounded-full text-white text-xs font-bold 
                                <?php 
                                    echo $task['state'] === 'pending' ? 'bg-orange-500' : 
                                         ($task['state'] === 'ongoing' ? 'bg-green-500' : 'bg-red-500'); 
                                ?>">
                                <?= ucfirst($task['state']) ?>
                            </span>
                            <form action="<?php echo WEB_ROOT; ?>/editTask" method="POST" class="inline">
                                <input type="hidden" name="id" value="<?= $task['id']; ?>">
                                <button class="bg-[#348888] text-white rounded-lg px-4 py-2 w-20" type="submit">Edit</button>
                            </form>
                        </div>
                        <div class="flex justify-between items-center">
                        <h2 class="text-lg font-bold mt-2"><?= htmlspecialchars($task['title']) ?></h2>
                        <form action="<?php echo WEB_ROOT; ?>/deleteConfirmation" method="POST" class="inline">
                            <input type="hidden" name="id" value="<?= $task['id']; ?>">
                            <button class="bg-[#C83804] text-white rounded-lg mt-2 mb-2 px-4 py-2 w-20" type="submit">Delete</button>
                            </form>
                        </div>
                        <p class="text-gray-600 text-sm"><?= htmlspecialchars($task['description']) ?></p>
                        <div class="text-gray-500 text-xs mt-2">
                            <span>Start time: <?=($task['start_time']) ?> </span> 
                            <span>End time: <?=($task['end_time']) ?></span> | 
                            <span class="font-bold">Added By: <?=($task['created_by']) ?></span>
                        </div>
                    </li>
                <?php endforeach; ?>
            <?php else: ?>
                <p class="text-center text-gray-600">No hay tareas registradas.</p>
            <?php endif; ?>
        </ul>
    </div>
</body>
</html>